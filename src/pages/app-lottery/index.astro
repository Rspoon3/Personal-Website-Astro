---
import Layout from "../../layouts/Layout.astro";
import LandingPageFooter from "../../components/LandingPageFooter.astro";
import { Icon } from "astro-icon/components";
import footerLinks from "../../json/footer_icons.json";

const features = [
  {
    icon: "bi:clock-fill",
    title: "Weekly Drawings",
    description: "Every Sunday at midnight UTC, a random app is automatically selected and featured on the homepage.",
  },
  {
    icon: "bi:shield-fill-check",
    title: "Verified Ownership",
    description: "Developers prove ownership by hosting a verification token at their website's .well-known path.",
  },
  {
    icon: "bi:people-fill",
    title: "Community Driven",
    description: "100% free for developers to submit their apps and participate in the lottery.",
  },
  {
    icon: "bi:star-fill",
    title: "Fair & Equal",
    description: "Every submitted app has an equal chance of being featured, regardless of past wins.",
  },
  {
    icon: "bi:phone-fill",
    title: "App Store Integration",
    description: "Automatically pulls app metadata, screenshots, and reviews directly from the App Store.",
  },
  {
    icon: "bi:share-fill",
    title: "Social Amplification",
    description: "Share featured apps across Bluesky, Mastodon, Threads, and X to help winners get discovered.",
  },
];

const techStack = [
  { name: "Next.js 16", color: "from-gray-600 to-gray-700" },
  { name: "React 19", color: "from-cyan-600 to-cyan-700" },
  { name: "TypeScript", color: "from-blue-600 to-blue-700" },
  { name: "Tailwind CSS v4", color: "from-teal-600 to-teal-700" },
  { name: "Supabase", color: "from-emerald-600 to-emerald-700" },
  { name: "Claude", color: "from-orange-600 to-orange-700" },
  { name: "Vercel", color: "from-gray-700 to-gray-800" },
];
---

<html lang="en">
  <head>
    <title>The App Lottery</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>
  <body class="text-white" style="background-color: #0c0a1d;">
    <!-- Header -->
    <header class="p-6" style="background-color: #141228;">
      <div class="flex items-center justify-between mx-auto max-w-6xl">
        <a href="/app-lottery" class="flex items-center hover:opacity-80 transition-opacity">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" class="h-10 w-10 mr-3">
            <polygon points="50,5 63,38 98,38 70,60 80,95 50,73 20,95 30,60 2,38 37,38" fill="#FACC15" stroke="#EAB308" stroke-width="2" stroke-linejoin="round"/>
          </svg>
          <h1 class="text-2xl font-bold">The App Lottery</h1>
        </a>
        <a href="https://theapplottery.com" target="_blank" rel="noopener noreferrer" class="text-lg text-purple-300 hover:text-purple-400 transition-colors">
          Visit Site &nearr;
        </a>
      </div>
    </header>

    <!-- Hero -->
    <section class="relative overflow-hidden py-20 md:py-32">
      <div class="absolute inset-0 bg-gradient-to-b from-indigo-900/20 via-purple-900/10 to-transparent"></div>
      <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" class="h-20 w-20 mx-auto mb-6">
          <polygon points="50,5 63,38 98,38 70,60 80,95 50,73 20,95 30,60 2,38 37,38" fill="#FACC15" stroke="#EAB308" stroke-width="2" stroke-linejoin="round"/>
        </svg>
        <h1 class="text-4xl md:text-6xl font-extrabold mb-4 bg-gradient-to-r from-indigo-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">
          The App Lottery
        </h1>
        <p class="text-xl md:text-2xl text-gray-300 mb-4">
          Discover a new app every Sunday
        </p>
        <p class="text-gray-400 max-w-2xl mx-auto mb-10">
          A weekly app discovery platform where iOS developers submit their apps for a fair chance to be featured. Every Sunday at midnight UTC, a random app is drawn and spotlighted with screenshots, reviews, and developer info.
        </p>
        <a
          href="https://theapplottery.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 text-white font-bold text-lg hover:opacity-90 transition-opacity"
        >
          Visit theapplottery.com
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-16 px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-extrabold text-center mb-12">How It Works</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-indigo-500 to-indigo-600 flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl font-bold">1</span>
            </div>
            <h3 class="text-lg font-bold mb-2">Developers Submit</h3>
            <p class="text-gray-400">Sign in with GitHub, look up your app, and verify ownership with a simple token.</p>
          </div>
          <div class="text-center">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-purple-500 to-purple-600 flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl font-bold">2</span>
            </div>
            <h3 class="text-lg font-bold mb-2">Weekly Drawing</h3>
            <p class="text-gray-400">Every Sunday at midnight UTC, a random app is automatically selected from the pool.</p>
          </div>
          <div class="text-center">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-pink-500 to-pink-600 flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl font-bold">3</span>
            </div>
            <h3 class="text-lg font-bold mb-2">Get Featured</h3>
            <p class="text-gray-400">The winning app is showcased with screenshots, reviews, ratings, and developer links.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="py-16 px-6" style="background-color: #141228;">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-extrabold text-center mb-12">Features</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
          {features.map((feature) => (
            <div class="flex items-start gap-4">
              <Icon name={feature.icon} class="text-2xl text-purple-400 flex-shrink-0 mt-1" />
              <div>
                <h3 class="text-lg font-bold">{feature.title}</h3>
                <p class="text-gray-400">{feature.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="py-16 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-extrabold mb-12">Built With</h2>
        <div class="flex flex-wrap justify-center gap-4">
          {techStack.map((tech) => (
            <span class={`px-5 py-2 rounded-full text-sm font-semibold bg-gradient-to-r ${tech.color} text-white`}>
              {tech.name}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 px-6">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl font-extrabold mb-4">Check It Out</h2>
        <p class="text-gray-400 mb-8">See this week's featured app and explore the winners archive.</p>
        <a
          href="https://theapplottery.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 text-white font-bold text-lg hover:opacity-90 transition-opacity"
        >
          Visit theapplottery.com
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </section>

    <LandingPageFooter bgColor="#141228" />
  </body>
</html>
